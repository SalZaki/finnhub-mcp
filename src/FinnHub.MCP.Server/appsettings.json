{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FinnHub": {
    "ApiKey": "",
    "BaseUrl": "https://finnhub.io/api/v1",
    "TimeoutSeconds": 10,
    "Endpoints": [
      {
        "Name": "search-symbol",
        "Url": "/search",
        "IsActive": true,
        "group": "search",
        "Description": "Searches for best-matching symbols based on specified query and exchange."
      },
      {
        "Name": "health-check",
        "Url": "/stock/symbol",
        "IsActive": true,
        "group": "stock",
        "Description": "Searches for best-matching symbols based on specified query."
      }
    ]
  },
  "Cache": {
    "QuoteTtl": "00:00:10",
    "NewsTtl": "00:01:00",
    "FinancialsTtl": "01:00:00",
    "ProfileTtl": "1.00:00:00",
    "ExchangesTtl": "7.00:00:00"
  }
}
